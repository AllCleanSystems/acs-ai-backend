PORT=3001
OPENAI_API_KEY=
OPENAI_MODEL=

# Twilio (optional if using email/password only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional: where to send internal alerts
ADMIN_ALERT_PHONE=
# Twilio Verify (OTP)
TWILIO_VERIFY_SERVICE_SID=

# Mobile auth (JWT + password)
MOBILE_JWT_SECRET=
# Optional: token TTL in seconds (default 12 hours)
MOBILE_JWT_TTL_SEC=
# Default passcode used only when technician has no password hash yet
MOBILE_DEFAULT_PASSCODE=joejoe23
# Optional brute-force protection for /mobile/auth/login
MOBILE_LOGIN_MAX_FAILED_ATTEMPTS=5
MOBILE_LOGIN_LOCKOUT_MS=900000

# Technicians auth field mapping (Zoho Creator link names)
ZOHO_CREATOR_TECHNICIAN_EMAIL_FIELD=email
ZOHO_CREATOR_TECHNICIAN_PASSWORD_HASH_FIELD=mobile_password_hash
# Leave blank if your technicians form has no active flag field
ZOHO_CREATOR_TECHNICIAN_ACTIVE_FIELD=
ZOHO_CREATOR_TECHNICIAN_AUTH_PROVIDER_FIELD=auth_provider

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CREATOR_OWNER=allcleansolutions
# Prefer the app link name (the part after the owner in the URL), e.g.:
# https://creatorapp.zoho.com/allcleansolutions/acs-control-center2
# This value can also be the full URL above; server.js will auto-extract the link name.
ZOHO_CREATOR_APP_LINK=acs-control-center2
ZOHO_CREATOR_BASE_URL=https://www.zohoapis.com
ZOHO_CREATOR_AI_INTAKE_FORM_LINK=ai_intake_log

# Report link names (defaults are fine if you didn't rename reports)
ZOHO_CREATOR_TECHNICIANS_REPORT_LINK=technicians_Report
ZOHO_CREATOR_WORK_ORDERS_REPORT_LINK=work_orders_Report

# FlutterFlow wrapper API auth (send header: x-acs-key)
FF_API_KEY=
