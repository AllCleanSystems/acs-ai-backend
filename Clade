// routes/admin-auth.js
// Admin-only endpoint to set a technician's mobile login password.
// Protected by x-admin-key header (set ADMIN_API_KEY in Railway env).

const express = require('express');
const bcrypt = require('bcryptjs');
const axios = require('axios');

const router = express.Router();

// ---------- helpers (self-contained so we don't touch server.js internals) ----------

function escapeCriteria(str) {
  return String(str || '').replace(/\\/g, '\\\\').replace(/"/g, '\\"');
}

async function creatorGetAccessToken() {
  const refreshToken = process.env.ZOHO_CREATOR_REFRESH_TOKEN;
  const clientId = process.env.ZOHO_CREATOR_CLIENT_ID;
  const clientSecret = process.env.ZOHO_CREATOR_CLIENT_SECRET;
  const accountsHost = process.env.ZOHO_ACCOUNTS_HOST || 'https://accounts.zoho.com';

  if (!refreshToken || !clientId || !clientSecret) {
    throw new Error('Zoho Creator OAuth env vars missing');
  }

  const url = `${accountsHost}/oauth/v2/token`;
  const params = new URLSearchParams({
    refresh_token: refreshToken,
    client_id: clientId,
    client_secret: clientSecret,
    grant_type: 'refresh_token'
  });
  const resp = await axios.post(url, params.toString(), {
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
  });
  if (!resp.data || !resp.data.access_token) {
    throw new Error('Zoho token refresh failed');
  }
  return resp.data.access_token;
}

async function creatorGetReport(reportLink, { criteria }) {
  const owner = process.env.ZOHO_CREATOR_OWNER || 'allcleansolutions';
  const app = process.env.ZOHO_CREATOR_APP || 'acs-control-center2';
  const apiHost = process.env.ZOHO_CREATOR_API_HOST || 'https://creator.zoho.com';
  const token = await creatorGetAccessToken();
  const url = `${apiHost}/api/v2/${owner}/${app}/report/${reportLink}`;
  const resp = await axios.get(url, {
    headers: { Authorization: `Zoho-oauthtoken ${token}` },
    params: criteria ? { criteria } : {}
  });
  return resp.data;
}

async function creatorUpdateRecord(reportLink, recordId, dataObj) {
  const owner = process.env.ZOHO_CREATOR_OWNER || 'allcleansolutions';
  const app = process.env.ZOHO_CREATOR_APP || 'acs-control-center2';
  const apiHost = process.env.ZOHO_CREATOR_API_HOST || 'https://creator.zoho.com';
  const token = await creatorGetAccessToken();
  const url = `${apiHost}/api/v2/${owner}/${app}/report/${reportLink}/${recordId}`;
  const resp = await axios.patch(
    url,
    { data: dataObj },
    {
      headers: {
        Authorization: `Zoho-oauthtoken ${token}`,
        'Content-Type': 'application/json'
      }
    }
  );
  return resp.data;
}

// ---------- the endpoint ----------

router.post('/set-tech-password', async (req, res) => {
  try {
    // 1. Admin key check
    const adminKey = req.headers['x-admin-key'];
    if (!process.env.ADMIN_API_KEY || adminKey !== process.env.ADMIN_API_KEY) {
      return res.status(401).json({ ok: false, error: 'Unauthorized' });
    }

    // 2. Validate body
    const { phone, email, password } = req.body || {};
    if (!password || String(password).length < 4) {
      return res
        .status(400)
        .json({ ok: false, error: 'password required (min 4 chars)' });
    }
    if (!phone && !email) {
      return res
        .status(400)
        .json({ ok: false, error: 'phone or email required' });
    }

    const reportLink =
      (process.env.ZOHO_CREATOR_TECHNICIANS_REPORT_LINK || 'technicians_Report').trim();

    // 3. Find technician
    let tech = null;
    if (phone) {
      const digits = String(phone).replace(/\D/g, '');
      const last10 = digits.length >= 10 ? digits.slice(-10) : '';
      const attempts = [phone];
      if (digits && digits !== phone) attempts.push(digits);
      if (last10 && last10 !== digits) attempts.push(last10);

      for (const val of attempts) {
        try {
          const criteria = `phone == "${escapeCriteria(val)}"`;
          const data = await creatorGetReport(reportLink, { criteria });
          const rows = data && Array.isArray(data.data) ? data.data : [];
          if (rows.length > 0) {
            tech = rows[0];
            break;
          }
        } catch (err) {
          const msg = String(err.message || '').toLowerCase();
          if (msg.includes('9280') || msg.includes('no records found')) continue;
          throw err;
        }
      }
    }
    if (!tech && email) {
      try {
        const criteria = `email == "${escapeCriteria(String(email).toLowerCase())}"`;
        const data = await creatorGetReport(reportLink, { criteria });
        const rows = data && Array.isArray(data.data) ? data.data : [];
        if (rows.length > 0) tech = rows[0];
      } catch (err) {
        const msg = String(err.message || '').toLowerCase();
        if (!msg.includes('9280') && !msg.includes('no records found')) throw err;
      }
    }

    if (!tech) {
      return res.status(404).json({ ok: false, error: 'Technician not found' });
    }

    // 4. Hash password and write to Zoho
    const hash = await bcrypt.hash(String(password), 10);
    await creatorUpdateRecord(reportLink, tech.ID, {
      Mobile_Password_Hash1: hash
    });

    // 5. Success
    const nameDisplay =
      (tech.tech_name && tech.tech_name.zc_display_value) ||
      (tech.tech_name && tech.tech_name.first_name) ||
      '';

    return res.json({
      ok: true,
      tech_id: tech.ID,
      name: nameDisplay,
      phone: tech.phone || null
    });
  } catch (err) {
    console.error('[admin/set-tech-password] error:', err.message);
    return res.status(500).json({
      ok: false,
      error: String(err.message || 'Internal error')
    });
  }
});

module.exports = router;
